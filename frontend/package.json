{
  "name": "dont-wanna-miss-a-thing",
  "version": "0.1.0",
  "private": false,
  "main": "main.js",
  "scripts": {
    "prod": "concurrently -k \"cross-env NODE_ENV=production webpack --mode production --config webpack.build.config.js && electron --noDevServer .\"  && \"cd ..\\backend\\ && TobiiServer.exe\"",
    "dev": "cross-env NODE_ENV=development webpack serve --hot --host 0.0.0.0 --config=./webpack.dev.config.js --mode development",
    "build": "cross-env NODE_ENV=production webpack --config webpack.build.config.js --mode production",
    "package": "npm run build",
    "start": "concurrently -k  \"start cmd /c ..\\backend\\TobiiServer.exe\" \"npm run dev\"",
    "postpackage": "electron-packager ./ --out=./builds"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@tsdotnet/stopwatch": "^2.0.9",
    "bitly": "^7.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2",
    "redux": "^5.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "subtitle": "^4.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@electron/packager": "^19.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^41.0.3",
    "electron-devtools-installer": "^4.0.0",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.1",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
